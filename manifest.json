{
    "manifest_version": 3,
    "name": "Simple Chords",
    "version": "1.0",

    "description": "Simplify guitar chord pages",

    "homepage_url": "https://github.com/duskygloom/simple_chords",
    
    "icons": {
        "16": "images/icon_16.png",
        "32": "images/icon_32.png",
        "48": "images/icon_48.png",
        "128": "images/icon_128.png"
    },

    "permissions": ["activeTab", "scripting"],
    "host_permissions": [
        "https://wrytin.com/*",
        "https://indichords.com/songs/*",
        "https://chordsfactory.com/*",
        "https://tabs.ultimate-guitar.com/tabs/*"
    ],

    "action": {
        "default_icon": "images/icon_48.png",
        "default_title": "Simplify",
        "default_popup": "index.html"
    }
}
